# 所有兼容openai接口的都可以
MODEL_BASE_URL=https://api.deepseek.com/v1
MODEL_ID=deepseek-chat
# your ds key
API_KEY=

# 可选：不设置时会按当前日期自动推导
# 例如 2026 年春季默认 2025-2026 / 2
SCHEDULE_YEAR=
SCHEDULE_TERM=

# --- Notion MCP（可选）：主 agent 通过 notion_mcp_* 工具调用 ---
# 在 Notion 集成中创建 Integration，复制 Secret（通常以 ntn_ / secret_ 开头）
NOTION_TOKEN=
# 默认使用 npx 启动官方包；需本机已安装 Node.js
# NOTION_MCP_COMMAND=npx
# NOTION_MCP_ARGS=-y @notionhq/notion-mcp-server
# 若使用官方托管 MCP（需按 Notion 文档完成 OAuth / 鉴权），可改为：
# NOTION_MCP_TRANSPORT=sse
# NOTION_MCP_SSE_URL=https://mcp.notion.com/mcp
